# ============================================================================
# Mem0 self-hosted — environment template (production / Dokploy)
# ============================================================================

# ----------------------------------------------------------------------------
# LLM / Embedder providers
# ----------------------------------------------------------------------------
# Mem0 needs a provider for BOTH the LLM (memory extraction) and the embedder
# (vector search). Bundled options:
#   LLMs:      openai, anthropic, gemini
#   Embedders: openai, gemini      <-- NOTE: anthropic CANNOT embed.
#
# So even if you want Claude as the LLM, you still need an OpenAI or Gemini
# key for embeddings. Simplest setup: just an OpenAI key for both.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Pin the default models (provider must be one of the bundled lists above).
MEM0_DEFAULT_LLM_MODEL=gpt-4.1-nano-2025-04-14
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-3-small

# ----------------------------------------------------------------------------
# Public URLs
# ----------------------------------------------------------------------------
# DASHBOARD_URL       = public origin of the dashboard. Doubles as the API's
#                       CORS allow-origin, so it MUST match exactly (scheme +
#                       host, no trailing slash) or the browser blocks calls.
# NEXT_PUBLIC_API_URL = public origin of the API. Baked into the dashboard at
#                       runtime so the browser knows where to send requests.
DASHBOARD_URL=https://mem0.example.com
NEXT_PUBLIC_API_URL=https://mem0-api.example.com

# Branding shown in the dashboard UI.
NEXT_PUBLIC_INSTANCE_NAME=Mem0

# ----------------------------------------------------------------------------
# Auth  (enabled by default — do NOT disable in production)
# ----------------------------------------------------------------------------
# JWT_SECRET signs access/refresh tokens. The server refuses to start without
# it. Generate one:   openssl rand -base64 48
JWT_SECRET=

# Legacy shared admin key (optional). Prefer per-user keys from the dashboard.
# ADMIN_API_KEY=

# Local-dev escape hatch only. Leave false in production.
AUTH_DISABLED=false

# ----------------------------------------------------------------------------
# Postgres  (pgvector + app/auth db live in the same instance)
# ----------------------------------------------------------------------------
# HOST/PORT are service-internal — leave as-is for the bundled db service.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
# Vector collection (table) name for stored memories.
POSTGRES_COLLECTION_NAME=memories
# App/auth db, created automatically by server/init-db.sh on first boot.
# If you change this, change the hardcoded name in init-db.sh too.
APP_DB_NAME=mem0_app

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# Anonymous onboarding telemetry. Off by default here; flip to true to opt in.
MEM0_TELEMETRY=false

# Days of request_logs to keep when `make prune-logs` runs. Wire that command
# into cron/systemd if you want automatic pruning in production.
REQUEST_LOG_RETENTION_DAYS=30
